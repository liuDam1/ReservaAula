## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][In][33]2/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Build tool reports
*.trx
*.xml

# DNX
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.res
*.sbr
*.lib
*.exp
*.dll
*.pdb
*.exe
*.manifest
*.res
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
*.opensdf
*.sdf
*.cache
*.set
*.opened
*.conf
*.config
*.psess
*.vsp
*.vspx
*.sap
*.dtbcache.json
*.iprochache
*.ltx
*.pfx
*.publishsettings

# ReSharper is a 3rd party add-on
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode is a 3rd party add-on
.JustCode

# TeamCity is a build server
_TeamCity*

# DotCover is a 3rd party add-on
*.dotCover

# AxoCover is a 3rd party add-on
.axoCover/*
!.axoCover/settings.json

# Coverlet is a 3rd party add-on
coverage.json
coverage.cobertura.xml
coverage.opencover.xml

# Visual Studio code coverage results
*.coverage
*.coveragexml

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
[Ee]xpress/

# DocProject is a 3rd party add-on
DocProject/buildhelp/
DocProject/Help/*.HxT
DocProject/Help/*.HxC
DocProject/Help/*.hhc
DocProject/Help/*.hhk
DocProject/Help/*.hhp
DocProject/Help/Html2
DocProject/Help/html

# ClickOnce directory
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
# Note: Comment the next line if you want to checkin your web deploy settings,
# but be aware that they may contain passwords.
*.pubxml
*.publishproj

# Microsoft Azure Web App publish settings. Comment the 2 lines below if you want to checkin those settings.
Properties/PublishProfiles
Properties/webjobs-list.json

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# If using the Visual Studio extension, uncomment the next line
# .nuget/NuGet.exe

# Microsoft Azure Build Output
csx/
*.cscfg
*.csdef

# Microsoft Azure Emulator
ecf/
rcf/

# Windows Azure Packaging projects
*.azurePubxml

# Codist Google Test Adapter
GuidanceExplorer.GuidanceExplorer
TestResults

# Node.js is a 3rd party add-on
node_modules/
jspm_packages/

# Visual Studio 2015 environments
.env

# Visual Studio 2015 Server
ServiceFabric/

# Backup & report files from converting an old project file
# to a newer Visual Studio version. Inspect them if you
# are upgrading your solution and then drop them.
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.bak

# Microsoft Fakes
FakesAssemblies/

# GhostDoc plugin setting file
*.GhostDoc.xml

# Node.js Tools for Visual Studio
.ntvs_analysis.dat
node_modules/

# Visual Studio 6 build log
*.plg

# Visual Studio 6-style IDE configuration file
*.opt

# Visual Studio 6 CLI options file
*.vbc

# Visual Studio LightSwitch build output
**/*.HTMLClient/GeneratedArtifacts
**/*.DesktopClient/GeneratedArtifacts
**/*.DesktopClient/ModelManifest.xml
**/*.Server/GeneratedArtifacts
**/*.Server/ModelManifest.xml
_Pvt_Extensions

# Paket dependency manager
.paket/paket.exe
paket-files/

# FAKE - F# Make
.fake/

# CodeRush personal settings
.cr/personal

# Python Tools for Visual Studio
*.pyc
*.pyo
pyproto/
__pycache__/
ptvs_virtualenv/

# JustDecompile stops generating this file on close, but sometimes it stick around
JustDecompileDump/

# Ionide (F# VS Code currently)
.ionide/

# Mac OS metadata
.DS_Store
